# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=v1

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Rol de app (RLS activo) — usar para operaciones normales
DATABASE_URL="postgresql://emr_app:emr_app_password@localhost:5432/emr_veterinaria"
# Rol migrador (BYPASSRLS) — solo para prisma migrate
DATABASE_MIGRATOR_URL="postgresql://emr_migrator:emr_migrator_password@localhost:5432/emr_veterinaria"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-access-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# ─── Throttler ───────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Storage (S3 / Cloudflare R2) ────────────────────────────────────────────
STORAGE_PROVIDER=s3
STORAGE_BUCKET=emr-files
STORAGE_REGION=us-east-1
# En dev: apuntar a MinIO local (docker-compose)
STORAGE_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=emr_minio
AWS_SECRET_ACCESS_KEY=emr_minio_password
STORAGE_PUBLIC_URL=http://localhost:9000/emr-files

# ─── Email (Mailhog local en dev) ────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@emrvet.local

# ─── Sentry (opcional en dev) ────────────────────────────────────────────────
SENTRY_DSN=
