# ─── Vercel environment variables ──────────────────────────────────────────────
# Copy these into Vercel → Project → Settings → Environment Variables

# URL de la API en Render (sin barra final)
NEXT_PUBLIC_API_URL=https://<api>.onrender.com/v1

# Resolución de tenant por header (no cambiar)
NEXT_PUBLIC_TENANT_RESOLUTION=header
NEXT_PUBLIC_DEV_TENANT_ID=demo-clinica

# Habilitar el editor de temas en producción
NEXT_PUBLIC_ENABLE_THEME_EDITOR=true
