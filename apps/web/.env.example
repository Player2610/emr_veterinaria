# ──────────────────────────────────────────────────────────────────────────────
# API
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ──────────────────────────────────────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────────────────────────────────────
# Secret used to sign/verify session tokens (min 32 chars)
AUTH_SECRET=change-me-to-a-random-32-char-string

# ──────────────────────────────────────────────────────────────────────────────
# Tenant resolution
# Set to "subdomain" to resolve tenant from subdomain, or "header" for
# X-Tenant-ID header (useful in development)
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TENANT_RESOLUTION=subdomain
# Used only when NEXT_PUBLIC_TENANT_RESOLUTION=header
NEXT_PUBLIC_DEV_TENANT_ID=

# ──────────────────────────────────────────────────────────────────────────────
# Feature flags
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_THEME_EDITOR=true
